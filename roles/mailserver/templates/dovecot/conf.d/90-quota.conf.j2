# {{ ansible_managed }}
# The global `mail_plugins = $mail_plugins quota` lives in 10-mail.conf so it
# loads before the protocol filters (see comment there). This file only holds
# the quota plugin configuration and the imap-specific addition.

plugin {
  quota = maildir:User quota
  quota_warning = storage={{ mailserver_quota_warning_percent }}%% quota-warning %u
  quota_status_success = DUNNO
  quota_status_nouser = REJECT Sorry, no such user
  quota_status_overquota = "452 4.2.2 Mailbox is full"
}

protocol imap {
  mail_plugins = $mail_plugins imap_quota
}
