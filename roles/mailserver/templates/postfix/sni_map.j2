{% if mailserver_certbot_challenge == "dns-ovh" %}
{% for d in mailserver_domains %}
{{ d }} /etc/letsencrypt/live/{{ d }}/privkey.pem /etc/letsencrypt/live/{{ d }}/fullchain.pem
*.{{ d }} /etc/letsencrypt/live/{{ d }}/privkey.pem /etc/letsencrypt/live/{{ d }}/fullchain.pem
{% endfor %}
{% endif %}
