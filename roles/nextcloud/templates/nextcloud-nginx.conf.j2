# Nextcloud & Collabora Online - nginx reverse proxy with SSL
# Managed by Ansible — do not edit manually

# ── HTTP: certbot challenges + redirect ──────────────────────────

server {
    listen 80;
    server_name {{ nextcloud_domain }} {{ collabora_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS: Nextcloud ─────────────────────────────────────────────

server {
    listen 443 ssl http2 proxy_protocol;
    server_name {{ nextcloud_domain }};

    ssl_certificate     {{ nextcloud_ssl_cert_path }}/fullchain.pem;
    ssl_certificate_key {{ nextcloud_ssl_cert_path }}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    set_real_ip_from  {{ reverse_proxy_ip }};
    real_ip_header    proxy_protocol;

    client_max_body_size 10G;
    fastcgi_buffers      64 4K;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains; preload" always;
    add_header Referrer-Policy          "no-referrer"                                   always;
    add_header X-Content-Type-Options   "nosniff"                                       always;
    add_header X-Frame-Options          "SAMEORIGIN"                                    always;
    add_header X-Robots-Tag             "noindex, nofollow"                              always;

    location / {
        proxy_pass http://127.0.0.1:{{ nextcloud_http_port }};
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $proxy_protocol_addr;
        proxy_set_header X-Forwarded-For   $proxy_protocol_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_buffering    off;
        proxy_request_buffering off;
    }

    location /.well-known/carddav {
        return 301 $scheme://$host/remote.php/dav;
    }

    location /.well-known/caldav {
        return 301 $scheme://$host/remote.php/dav;
    }

    location /.well-known/webfinger {
        return 301 $scheme://$host/index.php/.well-known/webfinger;
    }

    location /.well-known/nodeinfo {
        return 301 $scheme://$host/index.php/.well-known/nodeinfo;
    }
}

# ── HTTPS: Collabora Online ──────────────────────────────────────

server {
    listen 443 ssl http2 proxy_protocol;
    server_name {{ collabora_domain }};

    ssl_certificate     {{ collabora_ssl_cert_path }}/fullchain.pem;
    ssl_certificate_key {{ collabora_ssl_cert_path }}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    set_real_ip_from  {{ reverse_proxy_ip }};
    real_ip_header    proxy_protocol;

    # Static files
    location ^~ /browser {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Host $host;
    }

    # WOPI discovery
    location ^~ /hosting/discovery {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Host $host;
    }

    # Capabilities
    location ^~ /hosting/capabilities {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Host $host;
    }

    # Main websocket
    location ~ ^/cool/(.*)/ws$ {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host       $host;
        proxy_read_timeout 36000s;
    }

    # Download, upload, insertfile
    location ~ ^/(c|l)ool {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Host $host;
    }

    # Admin console websocket
    location ^~ /cool/adminws {
        proxy_pass http://127.0.0.1:{{ collabora_port }};
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host       $host;
        proxy_read_timeout 36000s;
    }
}
